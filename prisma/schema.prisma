generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// ENUMS (Dropdown Options)
// ========================

enum UserRole {
  GUEST
  REGISTERED
  ADMIN
}

enum ProjectStatus {
  IDEA
  PLANNING
  READY_TO_BUILD
  BUILDING
  TESTING
  LAUNCHED
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ========================
// MAIN TABLES
// ========================

model User {
  id                String           @id @default(uuid())
  full_name         String?
  email             String           @unique
  role              UserRole         @default(REGISTERED)
  subscription_plan SubscriptionPlan @default(FREE)
  image             String? // Google profile picture URL

  // Authentication Fields (For Google + Credentials)
  emailVerified DateTime?
  password      String? // For credential login later

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  projects      Project[]
  aiMessages    AiMessage[]
  exports       Export[]
  subscriptions Subscription[]
  payments      Payment[]
  activityLogs  ActivityLog[]

  @@map("users")
}

model Project {
  id               String        @id @default(uuid())
  user_id          String
  app_name         String?
  app_description  String?
  app_type         String? // Music, Marketplace, Etc.
  complexity_level String? // MVP, Standard, Advanced
  target_users     String?
  business_model   String? // Freemium, Subscription, etc.
  status           ProjectStatus @default(IDEA)

  // Extra Configs (JSON strings for flexibility)
  design_config       Json? // { color, font, style }
  security_config     Json? // List of selected features
  monetization_config Json? // { type, priceRange }

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  user           User                   @relation(fields: [user_id], references: [id])
  routes         ProjectRoute[]
  features       ProjectFeature[]
  databaseTables ProjectDatabaseTable[]
  aiMessages     AiMessage[]
  exports        Export[]
  activityLogs   ActivityLog[]

  @@map("projects")
}

model ProjectRoute {
  id           String  @id @default(uuid())
  project_id   String
  page_name    String
  route_path   String // e.g., /dashboard, /login
  purpose      String? // "User checks stats"
  components   Json? // ["Header", "Sidebar", "Table"]
  access_level String? // Guest / Registered / Admin
  status       String? // Planned / In Progress / Done
  sort_order   Int     @default(0)

  project Project @relation(fields: [project_id], references: [id])

  @@map("project_routes")
}

model ProjectFeature {
  id           String  @id @default(uuid())
  project_id   String
  feature_name String
  description  String?
  category     String? // Auth, UI, AI, Payment, etc.
  priority     String? // Must Have / Should Have / Future
  complexity   String? // Low / Medium / High
  status       String? // Planned / In Progress / Done

  project Project @relation(fields: [project_id], references: [id])

  @@map("project_features")
}

model ProjectDatabaseTable {
  id                 String  @id @default(uuid())
  project_id         String
  table_name         String // e.g., "Users", "Orders"
  purpose            String? // "Stores user data"
  fields_json        Json // [{ name: "id", type: "String" }]
  relationships_json Json? // ["userId -> User.id"]

  project Project @relation(fields: [project_id], references: [id])

  @@map("project_database_tables")
}

model AiMessage {
  id         String   @id @default(uuid())
  project_id String
  user_id    String
  role       String // 'user' | 'assistant' | 'system'
  message    String // Text content of message/chat
  metadata   Json? // Model used, tokens used, etc.
  created_at DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@map("ai_messages")
}

model Export {
  id             String   @id @default(uuid())
  project_id     String
  export_type    String // LOVABLE_PROMPT | DEV_BRIEF | PDF | FULL_SPEC
  export_content String // The actual text generated
  created_at     DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id])
  user    User?   @relation(fields: [userId], references: [id])
  userId  String?

  @@map("exports")
}

// ========================
// PLATFORM TABLES
// (For running the business)
// ========================

model AppTemplate {
  id               String   @id @default(uuid())
  template_name    String
  app_type         String // SaaS, Marketplace, etc.
  description      String?
  default_routes   Json? // Pre-made route array
  default_features Json? // Pre-made feature array
  default_database Json? // Pre-made table array
  image_url        String? // Thumbnail for template
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())

  @@map("app_templates")
}

model Subscription {
  id         String           @id @default(uuid())
  user_id    String
  plan_name  SubscriptionPlan
  status     String // Active, Cancelled, Expired
  start_date DateTime?
  end_date   DateTime?

  user     User      @relation(fields: [user_id], references: [id])
  payments Payment[]

  @@map("subscriptions")
}

model Payment {
  id               String        @id @default(uuid())
  user_id          String
  amount           Decimal       @db.Decimal(12, 2) // e.g., 99.00
  currency         String        @default("USD") // USD, ZAR, EUR
  payment_status   PaymentStatus @default(PENDING)
  payment_provider String // Stripe, PayPal
  provider_ref_id  String? // ID from Stripe/PayPal
  created_at       DateTime      @default(now())

  user           User          @relation(fields: [user_id], references: [id])
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId String?

  @@map("payments")
}

model ActivityLog {
  id         String   @id @default(uuid())
  user_id    String
  project_id String?
  action     String // CREATED_PROJECT, EXPORTED, UPDATED_ROUTES
  details    Json? // Extra data about the action
  created_at DateTime @default(now())

  user    User     @relation(fields: [user_id], references: [id])
  project Project? @relation(fields: [project_id], references: [id])

  @@map("activity_logs")
}
