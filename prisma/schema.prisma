generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(uuid())
  full_name         String?
  email             String?          @unique
  role              UserRole         @default(REGISTERED)
  subscription_plan SubscriptionPlan @default(FREE)
  image             String?
  emailVerified     DateTime?
  password          String?
  github_token      String?   // GitHub OAuth access token
  github_username   String?   // GitHub username
  github_connected  Boolean   @default(false)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  name              String?
  accounts          Account[]
  activityLogs      ActivityLog[]
  aiMessages        AiMessage[]
  exports           Export[]
  payments          Payment[]
  projects          Project[]
  sessions          Session[]
  subscriptions     Subscription[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id                  String                 @id @default(uuid())
  user_id             String
  app_name            String?
  app_description     String?
  app_type            String?
  complexity_level    String?
  target_users        String?
  business_model      String?
  status              ProjectStatus          @default(IDEA)
  design_config       Json?
  security_config     Json?
  monetization_config Json?
  created_at          DateTime               @default(now())
  updated_at          DateTime               @updatedAt
  activityLogs        ActivityLog[]
  aiMessages          AiMessage[]
  exports             Export[]
  databaseTables      ProjectDatabaseTable[]
  features            ProjectFeature[]
  files               ProjectFile[]
  routes              ProjectRoute[]
  versions            ProjectVersion[]
  user                User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("projects")
}

model ProjectRoute {
  id           String   @id @default(uuid())
  project_id   String
  page_name    String
  route_path   String
  purpose      String?
  components   Json?
  access_level String?
  status       String?
  sort_order   Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_routes")
}

model ProjectFeature {
  id           String   @id @default(uuid())
  project_id   String
  feature_name String
  description  String?
  category     String?
  priority     String?
  complexity   String?
  status       String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  project      Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_features")
}

model ProjectDatabaseTable {
  id                 String   @id @default(uuid())
  project_id         String
  table_name         String
  purpose            String?
  fields_json        Json
  relationships_json Json?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  project            Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_database_tables")
}

model ProjectFile {
  id         String   @id @default(uuid())
  project_id String
  file_path  String
  content    String
  language   String   @default("text")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([project_id, file_path])
  @@map("project_files")
}

model ProjectVersion {
  id             String   @id @default(uuid())
  project_id     String
  version_number Int
  label          String?
  instruction    String?
  files_snapshot Json
  created_at     DateTime @default(now())
  project        Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([project_id, version_number])
  @@map("project_versions")
}

model AiMessage {
  id         String   @id @default(uuid())
  project_id String
  user_id    String
  role       String
  message    String
  metadata   Json?
  created_at DateTime @default(now())
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

model Export {
  id             String   @id @default(uuid())
  project_id     String
  export_type    String
  export_content String
  created_at     DateTime @default(now())
  user_id        String?
  project        Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user           User?    @relation(fields: [user_id], references: [id])

  @@map("exports")
}

model AppTemplate {
  id               String   @id @default(uuid())
  template_name    String
  app_type         String
  description      String?
  default_routes   Json?
  default_features Json?
  default_database Json?
  image_url        String?
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("app_templates")
}

model Subscription {
  id         String           @id @default(uuid())
  user_id    String
  plan_name  SubscriptionPlan
  status     String
  start_date DateTime?
  end_date   DateTime?
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  payments   Payment[]
  user       User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Payment {
  id               String        @id @default(uuid())
  user_id          String
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("USD")
  payment_status   PaymentStatus @default(PENDING)
  payment_provider String
  provider_ref_id  String?
  created_at       DateTime      @default(now())
  subscription_id  String?
  updated_at       DateTime      @updatedAt
  subscription     Subscription? @relation(fields: [subscription_id], references: [id])
  user             User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ActivityLog {
  id         String   @id @default(uuid())
  user_id    String
  project_id String?
  action     String
  details    Json?
  created_at DateTime @default(now())
  project    Project? @relation(fields: [project_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

enum UserRole {
  GUEST
  REGISTERED
  ADMIN
}

enum ProjectStatus {
  IDEA
  PLANNING
  READY_TO_BUILD
  BUILDING
  TESTING
  LAUNCHED
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}
